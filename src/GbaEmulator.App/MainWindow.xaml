<Window x:Class="GbaEmulator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GBA Emulator"
        Width="960"
        Height="720"
        Background="#111418"
        KeyDown="OnKeyDown"
        KeyUp="OnKeyUp">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#05080C"
                BorderBrush="#303740"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
            <Viewbox Stretch="Uniform">
                <Image x:Name="FrameImage"
                       Width="240"
                       Height="160"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       SnapsToDevicePixels="True" />
            </Viewbox>
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Margin="4,12,4,0"
                   FontFamily="Consolas"
                   FontSize="13"
                   Foreground="#D6DEE7"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
